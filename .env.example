# GoGo Travel — environment template. Copy to .env and fill in.
# .env is gitignored (Law #1) — NEVER commit real values.

# --- apps/server ---
NODE_ENV=development
PORT=3000
# Postgres connection string (Neon in prod, local/postgres-js in tests). Unused until T-3.3.
DATABASE_URL=postgres://user:password@localhost:5432/gogo_travel

# --- apps/mobile (EXPO_PUBLIC_* are bundled into the client — no secrets here) ---
EXPO_PUBLIC_API_URL=http://localhost:3000
