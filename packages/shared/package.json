{
  "name": "@gogo/shared",
  "version": "0.0.1",
  "private": true,
  "description": "GoGo Travel shared contracts — Zod schemas as the single source of truth",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "eslint": "9.39.4",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
