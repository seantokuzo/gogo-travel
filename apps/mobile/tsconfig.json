{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // Explicit: TS 6 + pnpm doesn't reliably auto-include node_modules/@types
    // here; jest globals (describe/it/expect/jest) come from @types/jest.
    "types": ["jest"],
    "paths": {
      "@/*": ["./src/*"],
      "@/assets/*": ["./assets/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
