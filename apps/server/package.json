{
  "name": "@gogo/server",
  "version": "0.0.1",
  "private": true,
  "description": "GoGo Travel API — Hono + Drizzle/Postgres",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=.env src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@gogo/shared": "workspace:*",
    "@hono/node-server": "2.0.8",
    "@neondatabase/serverless": "1.1.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.29",
    "postgres": "3.4.9",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.4",
    "@types/node": "24.13.3",
    "@types/ws": "8.18.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
